# Batch Excel Processor Environment Configuration
# Copy this file to .env and modify the values as needed

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Processing Configuration
PROCESSING_CHUNK_SIZE=1000
CONFIDENCE_THRESHOLD=0.7
MAX_FILE_SIZE_MB=100

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000
DEBUG=false
LOG_LEVEL=info

# File Management
TEMP_DIR=./temp_files
MAX_STORAGE_GB=10.0

# Authentication
AUTH_ENABLED=true
SESSION_SECRET=change-this-secret-key-in-production

# Development Settings (set to true for development)
RELOAD=false
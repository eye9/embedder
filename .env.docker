# Docker Environment Configuration for Batch Excel Processor

# Application Environment
BATCH_PROCESSOR_ENV=production
BATCH_PROCESSOR_CONFIG=/app/batch_processor_config.yaml

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Web Application
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=1

# Security
SESSION_SECRET_KEY=change-this-secret-key-in-production-docker
AUTH_ENABLED=true

# File Management
TEMP_DIR=/app/temp_files
MAX_FILE_SIZE_MB=100
CLEANUP_INTERVAL_HOURS=1
AUTO_CLEANUP_ENABLED=true

# Processing Configuration
CHUNK_SIZE=1000
DEFAULT_ALGORITHM=similarity_top1
CONFIDENCE_THRESHOLD=0.7
LLM_TOP_K=5

# Logging
LOG_LEVEL=info
LOG_DIR=/app/logs

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# Monitoring (for Flower)
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin123
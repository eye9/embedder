<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- URL Rewrite правила для reverse proxy -->
        <rewrite>
            <rules>
                <!-- Редирект HTTP -> HTTPS (раскомментируйте для продакшн с SSL) -->
                <!--
                <rule name="Redirect to HTTPS" stopProcessing="true">
                    <match url=".*" />
                    <conditions>
                        <add input="{HTTPS}" pattern="off" ignoreCase="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:0}" redirectType="Permanent" />
                </rule>
                -->
                
                <!-- Правило для Flower мониторинга (защищено аутентификацией) -->
                <rule name="FlowerReverseProxy" stopProcessing="true">
                    <match url="^flower/(.*)" />
                    <conditions>
                        <add input="{REQUEST_METHOD}" pattern="GET|POST|PUT|DELETE" />
                    </conditions>
                    <action type="Rewrite" url="http://127.0.0.1:5555/{R:1}" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="{HTTPS}" />
                        <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
                        <set name="HTTP_X_ORIGINAL_HOST" value="{HTTP_HOST}" />
                        <set name="HTTP_X_FORWARDED_PORT" value="{SERVER_PORT}" />
                    </serverVariables>
                </rule>
                
                <!-- Правило для WebSocket соединений -->
                <rule name="WebSocketProxy" stopProcessing="true">
                    <match url="^ws/(.*)" />
                    <conditions>
                        <add input="{HTTP_CONNECTION}" pattern="Upgrade" ignoreCase="true" />
                        <add input="{HTTP_UPGRADE}" pattern="websocket" ignoreCase="true" />
                    </conditions>
                    <action type="Rewrite" url="ws://127.0.0.1:8000/ws/{R:1}" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="{HTTPS}" />
                        <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
                    </serverVariables>
                </rule>
                
                <!-- Основное правило для приложения -->
                <rule name="MainAppReverseProxy" stopProcessing="true">
                    <match url="^(?!flower/)(.*)" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="{HTTPS}" />
                        <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
                        <set name="HTTP_X_ORIGINAL_HOST" value="{HTTP_HOST}" />
                        <set name="HTTP_X_FORWARDED_PORT" value="{SERVER_PORT}" />
                    </serverVariables>
                </rule>
            </rules>
            
            <!-- Исходящие правила для корректировки ответов -->
            <outboundRules>
                <rule name="Add HSTS Header" preCondition="IsHTTPS">
                    <match serverVariable="RESPONSE_Strict_Transport_Security" pattern=".*" />
                    <action type="Rewrite" value="max-age=31536000; includeSubDomains; preload" />
                </rule>
                <preConditions>
                    <preCondition name="IsHTTPS">
                        <add input="{HTTPS}" pattern="on" />
                    </preCondition>
                </preConditions>
            </outboundRules>
        </rewrite>
        
        <!-- Настройки безопасности -->
        <security>
            <!-- Фильтрация запросов -->
            <requestFiltering>
                <!-- Максимальный размер загружаемого файла: 100MB -->
                <requestLimits maxAllowedContentLength="104857600" maxQueryString="2048" />
                
                <!-- Блокировка подозрительных расширений -->
                <fileExtensions>
                    <add fileExtension=".exe" allowed="false" />
                    <add fileExtension=".bat" allowed="false" />
                    <add fileExtension=".cmd" allowed="false" />
                    <add fileExtension=".com" allowed="false" />
                    <add fileExtension=".pif" allowed="false" />
                    <add fileExtension=".scr" allowed="false" />
                    <add fileExtension=".vbs" allowed="false" />
                </fileExtensions>
                
                <!-- Блокировка подозрительных последовательностей -->
                <denyUrlSequences>
                    <add sequence=".." />
                    <add sequence=":" />
                    <add sequence="%" />
                    <add sequence="&" />
                </denyUrlSequences>
                
                <!-- Ограничение HTTP методов -->
                <verbs>
                    <add verb="GET" allowed="true" />
                    <add verb="POST" allowed="true" />
                    <add verb="PUT" allowed="true" />
                    <add verb="DELETE" allowed="true" />
                    <add verb="HEAD" allowed="true" />
                    <add verb="OPTIONS" allowed="true" />
                    <add verb="TRACE" allowed="false" />
                    <add verb="TRACK" allowed="false" />
                </verbs>
            </requestFiltering>
            
            <!-- IP Security (раскомментируйте для ограничения доступа) -->
            <!--
            <ipSecurity>
                <add ipAddress="192.168.1.0" subnetMask="255.255.255.0" allowed="true" />
                <add ipAddress="203.0.113.0" subnetMask="255.255.255.0" allowed="true" />
                <add ipAddress="0.0.0.0" subnetMask="0.0.0.0" allowed="false" />
            </ipSecurity>
            -->
        </security>
        
        <!-- HTTP заголовки безопасности -->
        <httpProtocol>
            <customHeaders>
                <!-- Защита от clickjacking -->
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                
                <!-- Защита от MIME type sniffing -->
                <add name="X-Content-Type-Options" value="nosniff" />
                
                <!-- XSS защита -->
                <add name="X-XSS-Protection" value="1; mode=block" />
                
                <!-- Referrer Policy -->
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                
                <!-- Content Security Policy (настройте под ваши нужды) -->
                <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' ws: wss:;" />
                
                <!-- Скрытие версии сервера -->
                <remove name="Server" />
                <add name="Server" value="BatchProcessor" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Настройки сжатия -->
        <httpCompression>
            <scheme name="gzip" dll="%Windir%\system32\inetsrv\gzip.dll" />
            <dynamicTypes>
                <add mimeType="text/*" enabled="true" />
                <add mimeType="message/*" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="application/json" enabled="true" />
                <add mimeType="application/xml" enabled="true" />
                <add mimeType="*/*" enabled="false" />
            </dynamicTypes>
            <staticTypes>
                <add mimeType="text/*" enabled="true" />
                <add mimeType="message/*" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="application/atom+xml" enabled="true" />
                <add mimeType="application/xaml+xml" enabled="true" />
                <add mimeType="image/svg+xml" enabled="true" />
                <add mimeType="*/*" enabled="false" />
            </staticTypes>
        </httpCompression>
        
        <!-- Настройки кэширования для статических файлов -->
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            
            <!-- MIME типы для различных файлов -->
            <mimeMap fileExtension=".json" mimeType="application/json" />
            <mimeMap fileExtension=".woff" mimeType="font/woff" />
            <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
            <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
        </staticContent>
        
        <!-- Настройки по умолчанию -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.html" />
            </files>
        </defaultDocument>
        
        <!-- Обработка ошибок -->
        <httpErrors errorMode="Custom" defaultResponseMode="ExecuteURL">
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" path="/error/404" responseMode="ExecuteURL" />
            
            <remove statusCode="500" subStatusCode="-1" />
            <error statusCode="500" path="/error/500" responseMode="ExecuteURL" />
        </httpErrors>
        
        <!-- Настройки модулей -->
        <modules>
            <!-- Удаление ненужных модулей для безопасности -->
            <remove name="WebDAVModule" />
        </modules>
        
        <!-- Настройки обработчиков -->
        <handlers>
            <!-- Удаление ненужных обработчиков -->
            <remove name="WebDAV" />
            <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
            <remove name="OPTIONSVerbHandler" />
            <remove name="TRACEVerbHandler" />
        </handlers>
    </system.webServer>
    
    <!-- Настройки для ASP.NET (если используется) -->
    <system.web>
        <!-- Таймауты -->
        <httpRuntime 
            maxRequestLength="102400" 
            executionTimeout="300" 
            enableVersionHeader="false" 
            targetFramework="4.8" />
        
        <!-- Отключение отладки в продакшн -->
        <compilation debug="false" targetFramework="4.8" />
        
        <!-- Настройки сессий -->
        <sessionState 
            mode="Off" 
            cookieless="false" 
            regenerateExpiredSessionId="false" 
            cookieName="ASP.NET_SessionId" 
            cookieTimeout="20" 
            cookieSameSite="Strict" />
        
        <!-- Настройки безопасности -->
        <httpCookies 
            httpOnlyCookies="true" 
            requireSSL="false" 
            lockItem="true" />
        
        <!-- Отключение трассировки -->
        <trace enabled="false" localOnly="true" />
        
        <!-- Настройки машинного ключа (сгенерируйте уникальный для продакшн) -->
        <!--
        <machineKey 
            validationKey="[64-byte hex string]"
            decryptionKey="[24-byte hex string]"
            validation="HMACSHA256" 
            decryption="AES" />
        -->
    </system.web>
    
    <!-- Настройки для конкретных путей -->
    
    <!-- Flower мониторинг - требует аутентификацию -->
    <location path="flower">
        <system.webServer>
            <security>
                <authentication>
                    <basicAuthentication enabled="true" />
                    <anonymousAuthentication enabled="false" />
                </authentication>
                <authorization>
                    <!-- Разрешить доступ только администраторам -->
                    <add accessType="Allow" roles="Administrators" />
                    <add accessType="Allow" users="FlowerAdmin" />
                    <add accessType="Deny" users="*" />
                </authorization>
            </security>
        </system.webServer>
    </location>
    
    <!-- API endpoints - дополнительные ограничения -->
    <location path="api">
        <system.webServer>
            <security>
                <requestFiltering>
                    <!-- Более строгие ограничения для API -->
                    <requestLimits maxAllowedContentLength="52428800" /> <!-- 50MB для API -->
                </requestFiltering>
            </security>
        </system.webServer>
    </location>
    
    <!-- Health check endpoint - разрешить всем -->
    <location path="health">
        <system.webServer>
            <security>
                <authentication>
                    <anonymousAuthentication enabled="true" />
                </authentication>
            </security>
        </system.webServer>
    </location>
</configuration>